<Viewbox xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Stretch="Uniform">
    <Canvas Width="100" Height="100">
        <Canvas.Resources>
            <LinearGradientBrush x:Key="Id0Gradient" MappingMode="Absolute" 
                                 StartPoint="14.484,85.194" EndPoint="85.516,14.807">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="Id1Gradient" MappingMode="Absolute" 
                                 StartPoint="73.331,17.508" EndPoint="26.67,82.492">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="DotBrush" Color="#FF333333"/>
        </Canvas.Resources>

        <Rectangle Width="100" Height="100" Fill="{StaticResource Id0Gradient}"/>

        <Path Fill="{StaticResource Id1Gradient}"
              Data="M 10,10 H 90.001 V 90 H 10 V 10 Z M 12.667,12.666 V 87.334 H 87.334 V 12.666 H 12.667 Z" />

        <Ellipse Canvas.Left="42.5" Canvas.Top="21.191" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
        <Ellipse Canvas.Left="63.809" Canvas.Top="63.809" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
        <Ellipse Canvas.Left="21.191" Canvas.Top="63.809" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
        <Ellipse Canvas.Left="42.5" Canvas.Top="63.809" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
        <Ellipse Canvas.Left="31.846" Canvas.Top="42.5" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
        <Ellipse Canvas.Left="53.155" Canvas.Top="42.5" Width="15" Height="15" Fill="{StaticResource DotBrush}"/>
        
    </Canvas>
</Viewbox>
