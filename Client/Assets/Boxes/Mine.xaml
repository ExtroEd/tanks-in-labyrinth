<Viewbox xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Stretch="Uniform">
    <Canvas Width="100" Height="100">
        <Canvas.Resources>
            <LinearGradientBrush x:Key="Id0Brush" MappingMode="Absolute" 
                                 StartPoint="14.484,85.194" EndPoint="85.516,14.807">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="Id1Brush" MappingMode="Absolute" 
                                 StartPoint="73.331,17.508" EndPoint="26.67,82.492">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="MineBrush" Color="#FF333333"/>
        </Canvas.Resources>

        <Rectangle Width="100" Height="100" Fill="{StaticResource Id0Brush}"/>
        <Path Fill="{StaticResource Id1Brush}"
              Data="M 10,10 H 90.001 V 90 H 10 V 10 Z M 12.667,12.666 V 87.334 H 87.334 V 12.666 H 12.667 Z" />

        <Ellipse Canvas.Left="27" Canvas.Top="27" Width="46" Height="46" 
                 Fill="{StaticResource MineBrush}" 
                 Stroke="{StaticResource MineBrush}" StrokeThickness="1"/>

        <Line X1="50" Y1="20.224" X2="50" Y2="80.224" 
              Stroke="{StaticResource MineBrush}" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        
        <Line X1="20" Y1="50.224" X2="80" Y2="50.224" 
              Stroke="{StaticResource MineBrush}" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        
        <Line X1="28.787" Y1="29.011" X2="71.213" Y2="71.437" 
              Stroke="{StaticResource MineBrush}" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
        
        <Line X1="71.213" Y1="29.011" X2="28.786" Y2="71.437" 
              Stroke="{StaticResource MineBrush}" StrokeThickness="5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
              
    </Canvas>
</Viewbox>
