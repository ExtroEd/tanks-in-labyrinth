<Viewbox xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         Stretch="Uniform">
    <Canvas Width="100" Height="100">
        <Canvas.Resources>
            <LinearGradientBrush x:Key="Id0Gradient" MappingMode="Absolute" 
                                 StartPoint="14.484,85.194" EndPoint="85.516,14.807">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="Id1Gradient" MappingMode="Absolute" 
                                 StartPoint="73.331,17.508" EndPoint="26.67,82.492">
                <GradientStop Color="#FF595959" Offset="0"/>
                <GradientStop Color="#FF8C8C8C" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="DarkBrush" Color="#FF333333"/>
        </Canvas.Resources>

        <Rectangle Width="100" Height="100" Fill="{StaticResource Id0Gradient}"/>
        <Path Fill="{StaticResource Id1Gradient}"
              Data="M 10,10 H 90.001 V 90 H 10 V 10 Z M 12.667,12.666 V 87.334 H 87.334 V 12.666 H 12.667 Z" />

        <Rectangle Canvas.Left="44.499" Canvas.Top="37.702" Width="11" Height="36" Fill="{StaticResource DarkBrush}"/>

        <Line X1="46" Y1="27" X2="55" Y2="27" Stroke="{StaticResource DarkBrush}" StrokeThickness="1"/>

        <Rectangle Canvas.Left="48.512" Canvas.Top="66.703" Width="2.963" Height="14" Fill="{StaticResource DarkBrush}"/>

        <Path Fill="{StaticResource DarkBrush}" Stroke="{StaticResource DarkBrush}" 
              StrokeMiterLimit="22.9256" StrokeThickness="1"
              Data="M 50,26.202 L 55,36.203 H 45 L 50,26.202 Z 
                    M 32,80.203 L 43,62.203 V 72.203 L 32,80.203 Z 
                    M 68,80.203 L 57,62.203 V 72.203 L 68,80.203 Z" />

        <Path Stroke="{StaticResource DarkBrush}" StrokeThickness="3" 
              StrokeLineJoin="Round" StrokeMiterLimit="22.9256"
              Data="M 31.076,38.369 C 31.076,27.452 39.549,18.601 50,18.601 C 60.451,18.601 68.923,27.452 68.923,38.369" />
    </Canvas>
</Viewbox>
